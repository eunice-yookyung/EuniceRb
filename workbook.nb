4759a57d7848"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"w", "=", "0.75"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"gauss", "[", 
   RowBox[{"x_", ",", "w_"}], "]"}], ":=", 
  RowBox[{"Exp", "[", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"x", "^", "2"}]}], "/", 
    RowBox[{"w", "^", "2"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cut", "[", 
   RowBox[{"x_", ",", "a_", ",", "x0_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"gauss", "[", 
    RowBox[{
     RowBox[{"x", "-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "x0"}], ")"}]}], ",", "w"}], "]"}], " ", "-", 
   RowBox[{
    RowBox[{"Sqrt", "[", "a", "]"}], " ", 
    RowBox[{"gauss", "[", 
     RowBox[{"x", ",", "w"}], "]"}]}], " ", "+", " ", 
   RowBox[{"gauss", "[", 
    RowBox[{
     RowBox[{"x", "-", 
      RowBox[{"(", 
       RowBox[{"1", "-", "x0"}], ")"}]}], ",", " ", "w"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"cut", "[", 
       RowBox[{
        RowBox[{"-", "0.5"}], ",", "a", ",", "x0"}], "]"}], "==", "0"}], ",", 
     
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"cut", "[", 
         RowBox[{"0", ",", "a", ",", "x0"}], "]"}], "]"}], "-", 
       RowBox[{"Abs", "[", 
        RowBox[{"cut", "[", 
         RowBox[{"1", ",", "a", ",", "x0"}], "]"}], "]"}]}], "==", "0"}]}], 
    " ", "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"a", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x0", ",", "0"}], "}"}]}], "]"}]}], "Input",
